{
  "name": "sahayak-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "cd frontend && npm install && npm run build && cd ../srv && npm install && npm run build",
    "start": "cd frontend && npm run start",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:srv": "cd srv && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "build:srv": "cd srv && npm run build",
    "start:frontend": "cd frontend && npm run start",
    "start:srv": "cd srv && npm run start"
  },
  "dependencies": {
    "next": "16.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0"
  }
}
